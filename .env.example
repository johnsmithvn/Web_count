# Production Environment Template
# Copy to .env.production and fill in real values

# Application Environment
NODE_ENV=production

# JWT Secret (REQUIRED in production - generate a strong random string)
JWT_SECRET=your-super-secure-jwt-secret-here-please-change-this

# Database Configuration
DB_PATH=./database.db

# Server Configuration
PORT=5000
HOST=0.0.0.0

# Client Configuration (if serving from same server)
CLIENT_PORT=5001
CLIENT_HOST=0.0.0.0

# Security Settings (strict for production)
ENABLE_RATE_LIMITING=true
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_TIME=900000

# Rate Limiting Configuration
AUTH_RATE_LIMIT_WINDOW=900000
AUTH_RATE_LIMIT_MAX=5
API_RATE_LIMIT_WINDOW=900000
API_RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
LOG_TO_FILE=true
LOG_FILE_PATH=./logs/app.log

# Security Headers
ENABLE_SECURITY_HEADERS=true
ENABLE_HTTPS_REDIRECT=true

# Development Features (disabled in production)
ENABLE_DEBUG_ROUTES=false
ENABLE_MOCK_DATA=false

# Backup Configuration
ENABLE_AUTO_BACKUP=true
BACKUP_INTERVAL=86400000
BACKUP_RETENTION_DAYS=30
